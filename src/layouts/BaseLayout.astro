---
import { SEO } from 'astro-seo';
import Navbar from '../components/Navbar.astro';

export interface Props {
  title: string;
  description: string;
  image: string;
  type: string;
}

const { title, description, image, type } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <SEO
      {title}
      {description}
      canonical="https://antoni.ai"
      openGraph={{ basic: { image, title, description, type } }}
    />
  </head>
  <body>
    <!-- TODO: Navbar here -->
    <Navbar />
    <main class="px-4 mx-auto w-full max-w-4xl">
      <slot />
    </main>
    <!-- TODO: Footer here -->
  </body>
</html>
